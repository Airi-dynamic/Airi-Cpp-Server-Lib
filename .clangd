---
# 全局编译配置：告诉 clangd 使用 build/ 目录中的 compile_commands.json，
# 并对未在编译数据库中的文件（如未启用 MCPP_ENABLE_COROUTINES 时的 async/*.h、
# 未启用 MCPP_ENABLE_IO_URING 时的 io_uring 文件等）提供合理的回退编译参数。
#
# ⚠️ 关键修复（Xcode 26 / AppleClang 21 + Homebrew clangd 22）：
#   Homebrew clangd 默认用自带的 resource-dir（clang/22/include），其中的
#   <string.h>/<stddef.h> wrapper 与 Apple SDK 的 libc++ v1 不匹配，触发
#   `<cstring> tried including <string.h> but didn't find libc++'s` 报错。
#   通过 -resource-dir 显式指向 AppleClang 21 的内建头目录即可解决。
CompileFlags:
  CompilationDatabase: build
  Add:
    - -std=c++20
    - -Wno-unknown-warning-option
    - -resource-dir=/Applications/Xcode.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/lib/clang/21
Index:
  Background: Build
Diagnostics:
  UnusedIncludes: Strict
  MissingIncludes: None
---
# HISTORY/ 是历史快照，不属于当前项目构建，屏蔽全部诊断
If:
  PathExclude: HISTORY/.*
Diagnostics:
  Suppress: '*'
---
# examples/ 与 demo/ 有独立的 CMake 入口或编译规则，不在主 compile_commands.json 中
If:
  PathMatch:
    - examples/.*
    - demo/.*
Diagnostics:
  Suppress: '*'
---
# kqueue 文件仅 macOS 编译；epoll/io_uring 仅 Linux 编译。
# 针对当前未参与构建的平台目录，统一屏蔽诊断。
If:
  PathMatch:
    - .*/kqueue/.*\.cpp
    - .*/KqueuePoller\.h
    - .*/epoll/.*\.cpp
    - .*/EpollPoller\.h
    - .*/io_uring/.*\.cpp
    - .*/IoUringPoller\.h
Diagnostics:
  Suppress: ['*']
---
# Airi-Cpp-Server-Lib.h 是伞形头文件，unused include 警告无意义
If:
  PathMatch: .*/Airi-Cpp-Server-Lib\.h
Diagnostics:
  UnusedIncludes: None
---
# 协程/异步/内存池等 day32+ 新增模块，编译数据库依赖 MCPP_ENABLE_COROUTINES，
# 当未开启该选项时强制回退到 C++20 模式并补全平台特性宏
If:
  PathMatch:
    - .*/src/include/async/.*\.h
    - .*/src/include/memory/.*\.h
    - .*/src/common/async/.*\.cpp
    - .*/src/test/CoroutineTest\.cpp
    - .*/src/test/LockFreeQueueTest\.cpp
    - .*/src/test/MemoryPoolTest\.cpp
CompileFlags:
  Add:
    - -std=c++20
    - -DMCPP_HAS_COROUTINES=1
